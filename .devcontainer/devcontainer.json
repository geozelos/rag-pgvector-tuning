{
  "name": "rag-pgvector-tuning",
  "image": "mcr.microsoft.com/devcontainers/python:3.12-bookworm",

  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {},
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
      "moby": true
    }
  },

  "postCreateCommand": "curl -LsSf https://astral.sh/uv/install.sh | sh && export PATH=\"${HOME}/.local/bin:${PATH}\" && uv sync --group dev",

  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python"
      }
    }
  },

  "forwardPorts": [8000, 5433],

  "remoteEnv": {
    "PATH": "${containerEnv:HOME}/.local/bin:${containerEnv:PATH}",
    "DATABASE_URL": "postgresql://rag:rag@host.docker.internal:5433/rag"
  }
}
