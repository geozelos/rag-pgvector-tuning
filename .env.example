# Copy to ".env" and adjust. Used by pydantic-settings in src/rag/settings.py.
DATABASE_URL=postgresql://rag:rag@localhost:5433/rag

# Maximum number of chunks per POST /ingest/chunks request (default 500).
# MAX_INGEST_CHUNKS_PER_REQUEST=500

# Optional shared secret: when set, all routes except GET /health and GET /ready require Bearer or X-API-Key.
# RAG_API_KEY=

# --- Embedding backends (default: demo hash vectors; no external calls) ---
# EMBEDDING_BACKEND=demo
# EMBEDDING_BACKEND=openai
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_HTTP_TIMEOUT_S=60

# Local / OpenAI-compatible HTTP embeddings (Ollama, TEI, etc.):
# EMBEDDING_BACKEND=local
# LOCAL_EMBEDDINGS_BASE_URL=http://127.0.0.1:11434/v1
# LOCAL_EMBEDDING_MODEL=nomic-embed-text
# LOCAL_EMBEDDINGS_API_KEY=

# --- Operations / hardening ---
# REQUIRE_TENANT_ID=false
# CORS_ORIGINS=https://app.example.com,https://admin.example.com
# DISABLE_OPENAPI_UI=false
# RATE_LIMIT_PER_MINUTE=
