# Copy to ".env" and adjust. Used by pydantic-settings in src/rag/settings.py.
DATABASE_URL=postgresql://rag:rag@localhost:5433/rag

# Maximum number of chunks per POST /ingest/chunks request (default 500).
# MAX_INGEST_CHUNKS_PER_REQUEST=500

# Optional shared secret: when set, all routes except GET /health and GET /ready require Bearer or X-API-Key.
# RAG_API_KEY=
